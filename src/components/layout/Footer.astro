---
import { getCollection } from "astro:content";

const isDev = import.meta.env.DEV;

const publishedBlogEntries = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

publishedBlogEntries.sort((a, b) => {
  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});

const footerLinks = [
  {
    header: "About Us",
    links: [
      { name: "Home", href: "/", isExternal: false },
      { name: "Features", href: "/", isExternal: false },
      { name: "About", href: "/about", isExternal: false },
      { name: "Testimonial", href: "/", isExternal: false },
    ],
  },
  {
    header: "Features",
    links: [
      { name: "How it works", href: "/", isExternal: false },
      { name: "Privacy policy", href: "/privacy-policy", isExternal: false },
      { name: "Terms of Services", href: "/terms-of-services", isExternal: false },
      { name: "Refund policy", href: "/", isExternal: false },
    ],
  },
  {
    header: "Our Products",
    links: [
      { name: "Lineicons", href: "https://lineicons.com/", isExternal: true },
      { name: "TailAdmin", href: "https://tailadmin.com/", isExternal: true },
      { name: "TailGrids", href: "https://tailgrids.com/", isExternal: true },
      { name: "UIdeck", href: "https://uideck.com/", isExternal: true },
    ],
  },
  {
    header: "Latest blog",
    links: [],
  },
];

const socialLinks = [
  {
    name: "Facebook",
    href: "#",
    svgPath:
      "M16.294 8.86875H14.369H13.6815V8.18125V6.05V5.3625H14.369H15.8128C16.1909 5.3625 16.5003 5.0875 16.5003 4.675V1.03125C16.5003 0.653125 16.2253 0.34375 15.8128 0.34375H13.3034C10.5878 0.34375 8.69714 2.26875 8.69714 5.12187V8.1125V8.8H8.00964H5.67214C5.19089 8.8 4.74402 9.17812 4.74402 9.72812V12.2031C4.74402 12.6844 5.12214 13.1313 5.67214 13.1313H7.94089H8.62839V13.8188V20.7281C8.62839 21.2094 9.00652 21.6562 9.55652 21.6562H12.7878C12.994 21.6562 13.1659 21.5531 13.3034 21.4156C13.4409 21.2781 13.544 21.0375 13.544 20.8312V13.8531V13.1656H14.2659H15.8128C16.2596 13.1656 16.6034 12.8906 16.6721 12.4781V12.4438V12.4094L17.1534 10.0375C17.1878 9.79688 17.1534 9.52187 16.9471 9.24687C16.8784 9.075 16.569 8.90312 16.294 8.86875Z",
  },
  {
    name: "X",
    href: "#",
    svgPath:
      "M17.77 2.06h2.9l-6.34 7.24L21.78 19h-5.84l-4.57-5.97L6.15 19H3.24l6.78-7.75L2.88 2.06h5.99l4.13 5.45 4.77-5.45Zm-1.02 15.2h1.61L7.99 3.72H6.26l10.49 13.54Z",
  },
  {
    name: "Instagram",
    href: "#",
    svgPath:
      "M14.7554 1.8335H7.24463C4.25807 1.8335 1.83334 4.25823 1.83334 7.24479V14.6964C1.83334 17.7421 4.25807 20.1668 7.24463 20.1668H14.6962C17.7419 20.1668 20.1667 17.7421 20.1667 14.7555V7.24479C20.1667 4.25823 17.7419 1.8335 14.7554 1.8335ZM11.0296 15.4948C8.51614 15.4948 6.53496 13.4545 6.53496 11.0002C6.53496 8.54586 8.54571 6.50554 11.0296 6.50554C13.4839 6.50554 15.4946 8.54586 15.4946 11.0002C15.4946 13.4545 13.5134 15.4948 11.0296 15.4948ZM17.2393 6.91952C16.9436 7.24479 16.5 7.42221 15.9973 7.42221C15.5538 7.42221 15.1102 7.24479 14.7554 6.91952C14.4301 6.59425 14.2527 6.18027 14.2527 5.67758C14.2527 5.17489 14.4301 4.79049 14.7554 4.43565C15.0807 4.08081 15.4946 3.90339 15.9973 3.90339C16.4409 3.90339 16.914 4.08081 17.2393 4.40608C17.535 4.79049 17.7419 5.23403 17.7419 5.70715C17.7124 6.18027 17.535 6.59425 17.2393 6.91952Z",
  },
  {
    name: "LinkedIn",
    href: "#",
    svgPath:
      "M18.8065 1.8335H3.16399C2.42474 1.8335 1.83334 2.42489 1.83334 3.16414V18.8362C1.83334 19.5459 2.42474 20.1668 3.16399 20.1668H18.7473C19.4866 20.1668 20.078 19.5754 20.078 18.8362V3.13457C20.1371 2.42489 19.5457 1.8335 18.8065 1.8335ZM7.24464 17.4168H4.55379V8.69371H7.24464V17.4168ZM5.88443 7.48135C4.99733 7.48135 4.31721 6.77167 4.31721 5.91414C4.31721 5.05661 5.0269 4.34694 5.88443 4.34694C6.74196 4.34694 7.45163 5.05661 7.45163 5.91414C7.45163 6.77167 6.8011 7.48135 5.88443 7.48135ZM17.4463 17.4168H14.7554V13.1883C14.7554 12.183 14.7258 10.8523 13.336 10.8523C11.9167 10.8523 11.7097 11.976 11.7097 13.0996V17.4168H9.01884V8.69371H11.6506V9.90608H11.6801C12.0645 9.1964 12.9221 8.48672 14.2527 8.48672C17.0027 8.48672 17.5054 10.2609 17.5054 12.6856V17.4168H17.4463Z",
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer-shell relative z-10 overflow-hidden pt-20 lg:pt-24">
  <div class="footer-orb footer-orb-left" aria-hidden="true"></div>
  <div class="footer-orb footer-orb-right" aria-hidden="true"></div>

  <div class="container relative z-10">
    <div class="footer-top grid gap-6 rounded-3xl p-6 md:p-8 lg:grid-cols-12 lg:gap-8 lg:p-10">
      <div class="lg:col-span-4">
        <div class="h-full p-2 md:p-3">
          {!isDev ? (
            <a href="/" class="mb-6 inline-block max-w-[170px]">
              <img src="/assets/logo/logo-white.svg" alt="PAL logo" class="max-w-full" />
            </a>
          ) : (
            <a href="/" class="mb-6 inline-block text-2xl font-bold text-white">PAL</a>
          )}

          <p class="mb-6 max-w-[32ch] text-sm leading-7 text-slate-300 md:text-base">
            Trusted AI, marketing, and technology experts delivering measurable business outcomes for growth-focused teams.
          </p>

          <div class="flex flex-wrap gap-3">
            {socialLinks.map((social) => (
              <a
                href={social.href}
                aria-label={social.name}
                class="footer-social-chip"
                target={social.href.startsWith("http") ? "_blank" : undefined}
                rel={social.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                <svg viewBox="0 0 22 22" class="h-5 w-5 fill-current" aria-hidden="true">
                  <path d={social.svgPath}></path>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="grid gap-6 sm:grid-cols-3">
          {footerLinks.slice(0, 3).map((section) => (
            <div class="p-2 md:p-3">
              <h4 class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-cyan-300">{section.header}</h4>
              <ul class="space-y-3">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="footer-link inline-flex text-sm text-slate-300 md:text-[15px]"
                      target={link.isExternal ? "_blank" : undefined}
                      rel={link.isExternal ? "noopener noreferrer" : undefined}
                    >
                      {link.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="p-2 md:p-3">
          <h4 class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-cyan-300">{footerLinks[3].header}</h4>
          <ul class="space-y-4">
            {publishedBlogEntries.slice(0, 2).map((blogPostEntry) => (
              <li>
                <a class="group flex items-center gap-4" href={`/blog/${blogPostEntry.slug}`}>
                  <div class="h-14 w-14 overflow-hidden rounded-xl border border-white/20 bg-white/10">
                    {blogPostEntry.data.image?.src ? (
                      <img
                        src={blogPostEntry.data.image.src}
                        alt={blogPostEntry.data.image.alt || blogPostEntry.data.title}
                        class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center text-xs text-slate-300">BLOG</div>
                    )}
                  </div>
                  <span class="footer-link line-clamp-2 text-sm leading-6 text-slate-300">
                    {blogPostEntry.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom mt-8 flex flex-col gap-4 border-t border-white/15 py-6 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/privacy-policy" class="footer-meta-link">Privacy policy</a>
        <a href="/legal-notice" class="footer-meta-link">Legal notice</a>
        <a href="/terms-of-services" class="footer-meta-link">Terms of services</a>
      </div>
      <p class="text-sm text-slate-400">Copyright {currentYear} PAL. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    background:
      radial-gradient(circle at 10% 18%, rgba(54, 244, 200, 0.2) 0%, rgba(54, 244, 200, 0) 34%),
      radial-gradient(circle at 90% 10%, rgba(0, 210, 255, 0.22) 0%, rgba(0, 210, 255, 0) 38%),
      linear-gradient(155deg, #050b24 0%, #0b1f52 50%, #0a1538 100%);
  }

  .footer-top {
    border: 1px solid var(--brand-glass-border);
    background: linear-gradient(140deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
    backdrop-filter: blur(10px);
    box-shadow: var(--brand-shadow-strong);
  }

  .footer-social-chip {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(226, 239, 255, 0.9);
    background: rgba(255, 255, 255, 0.09);
    transition: transform var(--motion-hover), color var(--motion-hover), background-color var(--motion-hover), border-color var(--motion-hover);
  }

  .footer-social-chip:hover {
    transform: translateY(-2px);
    color: #031535;
    background: linear-gradient(92deg, #00d2ff 0%, #36f4c8 100%);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .footer-link {
    position: relative;
    transition: color var(--motion-hover), transform var(--motion-hover);
  }

  .footer-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    height: 1px;
    width: 0;
    background: linear-gradient(90deg, #00d2ff, #36f4c8);
    transition: width var(--motion-hover);
  }

  .footer-link:hover {
    color: #f8fbff;
    transform: translateX(2px);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  .footer-meta-link {
    font-size: 0.9rem;
    color: rgb(187 202 224 / 0.95);
    transition: color var(--motion-hover);
  }

  .footer-meta-link:hover {
    color: #ffffff;
  }

  .footer-orb {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(24px);
    opacity: 0.58;
  }

  .footer-orb-left {
    left: -140px;
    top: 28px;
    height: 300px;
    width: 300px;
    background: radial-gradient(circle, rgba(54, 244, 200, 0.62), rgba(54, 244, 200, 0));
  }

  .footer-orb-right {
    right: -140px;
    bottom: 14px;
    height: 320px;
    width: 320px;
    background: radial-gradient(circle, rgba(0, 210, 255, 0.62), rgba(0, 210, 255, 0));
  }

  @media (max-width: 767px) {
    .footer-orb-left,
    .footer-orb-right {
      height: 220px;
      width: 220px;
    }
  }
</style>
