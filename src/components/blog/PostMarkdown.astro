---
import Layout from '../../layouts/Layout.astro';
import Newsletterbox from '../Newsletterbox.astro';
import PopularArticles from '../PopularArticles.astro';
import RelatedArticles from '../RelatedArticles.astro';

interface Props { 
  entry: any
  Content: any
}

const { entry, Content } = Astro.props;
const defaultImage = entry.data.image?.src || '/assets/blog/blog-default.jpg';
const defaultBigImage = entry.data.bigImg?.src || '/assets/blog/blog-details-default.jpg';
const defaultAuthorImage = entry.data.authorImg?.src || '/assets/blog/author-01.png';
const defaultComments = entry.data.comments || '0';
const defaultViews = entry.data.views || '0';
---

<Layout title={entry.data.title} description={entry.data.snippet} image={defaultBigImage}>
  <!-- ====== Blog Details Section Start -->
  <section class="pt-20 pb-10 lg:pt-[120px] lg:pb-20 dark:bg-dark">
    <div class="container text-base text-body-color dark:text-dark-6">
      <div class="-mx-4 flex flex-wrap justify-center">
        <div class="w-full px-4">
          <div
            class="wow fadeInUp relative z-20 mb-[50px] h-[300px] overflow-hidden rounded-[5px] md:h-[400px] lg:h-[500px] "
            data-wow-delay=".1s"
          >
            <!-- <img
              src={defaultBigImage}
              alt={entry.data.bigImg?.alt || 'Blog post image'}
              class="h-full w-full object-cover object-center"
            /> -->
              <!-- Theme-aware SVG background: uses currentColor so Tailwind text color controls light/dark -->
              <svg id="eWSLi8rbaTl1" class="absolute inset-0 w-full h-full -z-10 text-white dark:text-dark" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 700 400" shape-rendering="geometricPrecision" text-rendering="geometricPrecision" width="700" height="400" preserveAspectRatio="none" aria-hidden="true">
                <rect width="100%" height="100%" rx="10" ry="10" fill="currentColor" />
                <style><![CDATA[#eWSLi8rbaTl2 {animation: eWSLi8rbaTl2_s_do 12000ms linear infinite normal forwards}@keyframes eWSLi8rbaTl2_s_do { 0% {stroke-dashoffset: 0} 100% {stroke-dashoffset: 300}} #eWSLi8rbaTl3 {animation: eWSLi8rbaTl3_s_do 12000ms linear infinite normal forwards}@keyframes eWSLi8rbaTl3_s_do { 0% {stroke-dashoffset: 0} 100% {stroke-dashoffset: 360}} #eWSLi8rbaTl4 {animation: eWSLi8rbaTl4_s_do 12000ms linear infinite normal forwards}@keyframes eWSLi8rbaTl4_s_do { 0% {stroke-dashoffset: 0} 100% {stroke-dashoffset: 500}} #eWSLi8rbaTl5 {animation: eWSLi8rbaTl5_s_do 12000ms linear infinite normal forwards}@keyframes eWSLi8rbaTl5_s_do { 0% {stroke-dashoffset: 0} 100% {stroke-dashoffset: 360}}]]></style>
                <!-- Theme-aware gradient colors via CSS variables -->
                <style>
                  :root {
                    --g2-0: #0036a4; --g2-1: #6a2364; --g2-2: #4cceff;
                    --g3-0: #ffffff; --g3-1: #359fad; --g3-2: #ffffff;
                    --g4-0: #ae3bd4; --g4-1: #2bc4c3; --g4-2: #ff00f6;
                    --g5-0: rgba(34,56,133,0.52); --g5-1: rgba(255,176,195,0.77);
                  }
                  /* When a dark class is present on html/body (Tailwind dark mode), override for dark theme */
                  html.dark, .dark {
                    --g2-0: #06233a; --g2-1: #3b1b33; --g2-2: #1f6f8b;
                    --g3-0: #e6f6fa; --g3-1: #2a6b6b; --g3-2: #e6f6fa;
                    --g4-0: #8b2fa6; --g4-1: #1f8b8a; --g4-2: #c400d6;
                    --g5-0: rgba(20,30,60,0.5); --g5-1: rgba(120,50,80,0.6);
                  }
                </style>
              <defs>
                <linearGradient id="eWSLi8rbaTl2-stroke" x1="0" y1="0.5" x2="1" y2="0.5" spreadMethod="pad" gradientUnits="objectBoundingBox" gradientTransform="translate(0 0)"><stop id="eWSLi8rbaTl2-stroke-0" offset="0%" stop-color="var(--g2-0)"/><stop id="eWSLi8rbaTl2-stroke-1" offset="49%" stop-color="var(--g2-1)"/><stop id="eWSLi8rbaTl2-stroke-2" offset="100%" stop-color="var(--g2-2)"/></linearGradient>
                <linearGradient id="eWSLi8rbaTl3-stroke" x1="0" y1="0.5" x2="1" y2="0.5" spreadMethod="pad" gradientUnits="objectBoundingBox" gradientTransform="translate(0 0)"><stop id="eWSLi8rbaTl3-stroke-0" offset="0%" stop-color="var(--g3-0)"/><stop id="eWSLi8rbaTl3-stroke-1" offset="48%" stop-color="var(--g3-1)"/><stop id="eWSLi8rbaTl3-stroke-2" offset="100%" stop-color="var(--g3-2)"/></linearGradient>
                <linearGradient id="eWSLi8rbaTl4-stroke" x1="0" y1="0.5" x2="1" y2="0.5" spreadMethod="pad" gradientUnits="objectBoundingBox" gradientTransform="translate(0 0)"><stop id="eWSLi8rbaTl4-stroke-0" offset="0%" stop-color="var(--g4-0)"/><stop id="eWSLi8rbaTl4-stroke-1" offset="48%" stop-color="var(--g4-1)"/><stop id="eWSLi8rbaTl4-stroke-2" offset="100%" stop-color="var(--g4-2)"/></linearGradient>
                <radialGradient id="eWSLi8rbaTl5-stroke" cx="0" cy="0" r="0.5" spreadMethod="pad" gradientUnits="objectBoundingBox" gradientTransform="translate(0.5 0.5)"><stop id="eWSLi8rbaTl5-stroke-0" offset="0%" stop-color="var(--g5-0)"/><stop id="eWSLi8rbaTl5-stroke-1" offset="100%" stop-color="var(--g5-1)"/></radialGradient>
              </defs>
