    title: 'Solution Architecture',
    ref: '/contact',
    refTitle: 'Discuss Solution',
    impact: 'Roadmaps that reduce risk and improve ROI',
    description:
      'We design and maintain scalable technology roadmaps tailored to business priorities, helping teams identify high-value investments and define practical evolution plans.',
  },
  {
    icon: 'assets/services/proffesional-services.svg',
    category: 'Technology Delivery',
    title: 'Professional Services',
    ref: '/contact',
    refTitle: 'Discuss Solution',
    impact: 'Faster adoption of modern platforms',
    description:
      'We help organizations adopt modern services and technologies with structured implementation support that improves utilization, simplifies operations, and accelerates outcomes.',
  },
  {
