    description:
      'We build enterprise-grade agentic systems with custom orchestration, MCP integration, production hardening, and continuous improvement frameworks to drive efficiency and innovation.',
  },
  {
    icon: 'assets/services/integration.svg',
    category: 'Technology Integration',
    title: 'Integration',
    ref: '/contact',
    refTitle: 'Discuss Solution',
    impact: 'Reliable API, cloud, and B2B connectivity',
    description:
      'We implement integration architectures spanning API, cloud, B2B, SOA, and hybrid ecosystems using agile and DevOps practices for faster, safer delivery.',
  },
  {
    icon: 'assets/features/icon-03.svg',
    category: 'Data Foundations',
