const serviceMetrics = [
  {
    value: '3',
    label: 'Core Expertise Domains',
    detail: 'Generative AI, Marketing, Technology'
  },
  {
    value: '9',
    label: 'Solution Tracks',
    detail: 'From strategy, build, integration, and scale'
  },
  {
    value: 'End-to-End',
    label: 'Delivery Model',
    detail: 'Advisory, implementation, and optimization'
  }
];
---

<!-- ====== Services Section Start -->
<section id="services" class="services-section relative overflow-hidden pt-20 pb-10 lg:pt-[120px] lg:pb-[80px]">
  <div class="services-glow services-glow-a" aria-hidden="true"></div>
  <div class="services-glow services-glow-b" aria-hidden="true"></div>
  <div class="container">
    <div class="-mx-4 flex flex-wrap">
      <div class="w-full px-4">
        <div class="mb-12 mx-auto max-w-[760px] lg:mb-14 text-center">
          <span class="services-pill mb-4 inline-flex">
            AI, Marketing, and Technology Solutioning
          </span>
          <h2 class="services-heading mb-4 text-3xl font-bold sm:text-4xl md:text-[44px] md:leading-[1.15]">
            Services That Turn Expertise Into Business Growth
          </h2>
          <p class="services-subheading mx-auto max-w-[680px] text-base sm:text-lg">
            We deliver outcome-focused offerings across Generative AI, modern marketing systems, and advanced technology consulting to help teams scale with confidence.
          </p>
        </div>
      </div>
    </div>

    <div class="-mx-4 mb-10 flex flex-wrap lg:mb-14">
      {
        serviceMetrics.map((metric) => (
          <div class="w-full px-4 md:w-1/3">
            <div class="services-metric-card mb-4 md:mb-0">
              <p class="services-metric-value">{metric.value}</p>
              <p class="services-metric-label">{metric.label}</p>
              <p class="services-metric-detail">{metric.detail}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service, index) => (
          <div>
            <article class="service-card wow fadeInUp group h-full" data-wow-delay={`${0.08 + index * 0.02}s`}>
              <div class="mb-4 flex items-start justify-between gap-3">
                <span class="service-category">{service.category}</span>
                <span class="service-step">{String(index + 1).padStart(2, '0')}</span>
              </div>

              <div
                class="service-icon-wrap relative z-10 mb-6 flex h-[70px] w-[70px] items-center justify-center rounded-[14px]"
              >
                <span
                  class="service-icon-shadow absolute top-0 left-0 -z-[1] mb-8 flex h-[70px] w-[70px] rotate-[18deg] items-center justify-center rounded-[14px] duration-300 group-hover:rotate-45"
                ></span>
                <img src={service.icon} alt={`${service.title} icon`} />
              </div>

              <h4 class="service-title mb-3 text-xl font-bold">
                {service.title}
              </h4>

              <p class="service-description mb-5">
                {service.description}
              </p>

              <p class="service-impact mb-6">{service.impact}</p>

              <a
                href={service.ref}
                class="service-link inline-flex items-center gap-2 text-sm font-semibold"
              >
                {service.refTitle}
                <span aria-hidden="true">-></span>
              </a>
            </article>
          </div>
        ))
      }
    </div>
  </div>
</section>
<!-- ====== Features Section End -->

<style>
  .services-section {
    position: relative;
    background:
      radial-gradient(circle at 12% 8%, rgba(74, 236, 201, 0.16) 0%, rgba(74, 236, 201, 0) 46%),
      radial-gradient(circle at 88% 12%, rgba(32, 140, 255, 0.18) 0%, rgba(32, 140, 255, 0) 42%),
      linear-gradient(180deg, #f4f8ff 0%, #ecf4ff 48%, #f8fbff 100%);
  }

  :global(.dark) .services-section {
    background:
      radial-gradient(circle at 14% 10%, rgba(74, 236, 201, 0.18) 0%, rgba(74, 236, 201, 0) 40%),
      radial-gradient(circle at 90% 15%, rgba(32, 140, 255, 0.24) 0%, rgba(32, 140, 255, 0) 42%),
      linear-gradient(180deg, #081024 0%, #0a1632 52%, #0d1c3e 100%);
  }

  .services-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(20px);
    pointer-events: none;
  }

  .services-glow-a {
    width: 280px;
    height: 280px;
    top: 2%;
    left: 1%;
    background: radial-gradient(circle, rgba(0, 211, 255, 0.26) 0%, rgba(0, 211, 255, 0) 72%);
    animation: servicesFloat var(--motion-float-fast, 8s) ease-in-out infinite;
  }

  .services-glow-b {
    width: 320px;
    height: 320px;
    bottom: 4%;
    right: 1%;
    background: radial-gradient(circle, rgba(72, 238, 198, 0.24) 0%, rgba(72, 238, 198, 0) 72%);
    animation: servicesFloat var(--motion-float-slow, 10s) ease-in-out infinite reverse;
  }

  .services-pill {
    border: 1px solid rgba(26, 117, 255, 0.25);
    border-radius: 999px;
    padding: 0.45rem 0.95rem;
    background: rgba(255, 255, 255, 0.8);
    color: #0b4fc4;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }

  :global(.dark) .services-pill {
    border-color: rgba(115, 191, 255, 0.3);
    background: rgba(13, 32, 67, 0.6);
    color: #9fceff;
  }

  .services-heading {
    color: #0c1733;
    text-wrap: balance;
  }

  :global(.dark) .services-heading {
    color: #f2f6ff;
  }

  .services-subheading {
    color: #4d6285;
  }

  :global(.dark) .services-subheading {
