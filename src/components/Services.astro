  }

  .services-metric-card {
    height: 100%;
    border-radius: 1rem;
    border: 1px solid rgba(64, 123, 218, 0.2);
    background: rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(8px);
    padding: 1rem;
    box-shadow: 0 16px 28px rgba(16, 49, 111, 0.08);
  }

  :global(.dark) .services-metric-card {
