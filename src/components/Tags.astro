---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="wow fadeInUp mb-12 w-full bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900 rounded-lg py-8 px-4 sm:px-6 md:px-8 border border-gray-200 dark:border-gray-700"
  data-wow-delay=".1s"
>
  <div class="flex flex-col items-center justify-center gap-6">
    <div class="text-center">
      <h3 class="text-lg md:text-2xl font-semibold text-dark dark:text-white mb-2">
        Tags
      </h3>
      <p class="text-lg text-body-color dark:text-dark-6">
        Explore related topics and discover more content
      </p>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-3 w-full">
    {
      tags.map((tag: string) => (
        <a
          href="javascript:void(0)"
          class="inline-block rounded-full bg-gradient-to-r from-primary/10 to-primary/5 dark:from-primary/20 dark:to-primary/15 py-2 px-4 text-sm md:text-base font-medium text-primary dark:text-primary-light hover:from-primary/20 hover:to-primary/10 dark:hover:from-primary/30 dark:hover:to-primary/25 transition-all duration-200 border border-primary/20 dark:border-primary/30 hover:border-primary/40 dark:hover:border-primary/50"
        >
          {tag}
        </a>
      ))
    }
    </div>
  </div>
</div>
