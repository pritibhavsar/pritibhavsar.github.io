---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Our Privacy Policy explains how PAL Portals collects, uses, and protects your personal data in compliance with Indian, US, and UK regulations."
  title="Privacy Policy | PAL Portals"
>
  <Breadcrumb>
    <Fragment slot="title">Privacy Policy</Fragment>
  </Breadcrumb>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <!-- Introduction -->
        <div class="mb-12">
          <h1 class="text-3xl font-bold text-dark dark:text-white mb-4">Privacy Policy</h1>
          <p class="text-body-color dark:text-dark-6 text-lg">
            <strong>Effective Date:</strong> January 2, 2026
          </p>
          <p class="text-body-color dark:text-dark-6 mt-4">
            PAL Portals ("Company," "we," "us," "our," or "Service Provider") is committed to protecting your privacy and ensuring transparency about how we collect, use, and safeguard your personal data. This Privacy Policy outlines our practices in compliance with applicable laws, including the Digital Personal Data Protection Act, 2023 (DPDPA) of India, the General Data Protection Regulation (GDPR) of the EU and UK, and the California Consumer Privacy Act (CCPA) of the United States.
          </p>
        </div>

        <!-- 1. Information We Collect -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">1. Information We Collect</h2>
          
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">1.1 Information You Provide Directly</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li><strong>Contact Information:</strong> Name, email address, phone number, company name, job title</li>
              <li><strong>Account Information:</strong> Username, password, profile information</li>
              <li><strong>Communication Data:</strong> Messages, inquiries, feedback, and support requests</li>
              <li><strong>Business Information:</strong> Company details, business requirements, service preferences</li>
              <li><strong>Payment Information:</strong> Billing address, payment method details (processed securely through third-party payment processors)</li>
            </ul>
          </div>

          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">1.2 Information Collected Automatically</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li><strong>Technical Data:</strong> IP address, browser type, device information, operating system</li>
              <li><strong>Usage Data:</strong> Pages visited, time spent, clicks, links followed</li>
              <li><strong>Cookies and Similar Technologies:</strong> Session cookies, tracking pixels, analytics tools</li>
              <li><strong>Location Data:</strong> General geographic location (country/city level) based on IP address</li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">1.3 Information from Third Parties</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Business partners and service providers</li>
              <li>Publicly available sources</li>
              <li>Marketing platforms and analytics providers</li>
            </ul>
          </div>
        </div>

        <!-- 2. Legal Basis for Processing -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">2. Legal Basis for Processing</h2>
          
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under DPDPA (India):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Your explicit consent for processing personal data</li>
              <li>Performance of contracts with you</li>
              <li>Compliance with legal obligations</li>
              <li>Protection of vital interests</li>
              <li>Legitimate interests of the Company and others</li>
            </ul>
          </div>

          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under GDPR (EU/UK):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Explicit consent</li>
              <li>Contract performance</li>
              <li>Legal obligation compliance</li>
              <li>Vital interests protection</li>
              <li>Public task performance</li>
              <li>Legitimate interests</li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under CCPA (USA):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Providing services as per the California Consumer Privacy Act</li>
              <li>Fulfilling contractual obligations</li>
              <li>Preventing fraud and ensuring security</li>
            </ul>
          </div>
        </div>

        <!-- 3. How We Use Your Information -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">3. How We Use Your Information</h2>
          <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
            <li>Providing, maintaining, and improving our services</li>
            <li>Processing transactions and sending related information</li>
            <li>Sending marketing communications (with consent)</li>
            <li>Responding to inquiries and customer support</li>
            <li>Conducting analytics and tracking website performance</li>
            <li>Personalizing user experience</li>
            <li>Complying with legal and regulatory requirements</li>
            <li>Detecting and preventing fraud and security issues</li>
            <li>Enforcing our terms and conditions</li>
            <li>Business analytics and strategic planning</li>
          </ul>
        </div>

        <!-- 4. Data Sharing and Disclosure -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">4. Data Sharing and Disclosure</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-6">
            We may share your personal data in the following circumstances:
          </p>

          <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside mb-6">
            <li><strong>Service Providers:</strong> Third parties who assist us in operating our website, conducting business, or servicing you</li>
            <li><strong>Business Partners:</strong> With your consent, we may share data with partners for marketing purposes</li>
            <li><strong>Legal Requirements:</strong> When required by law, court order, or governmental authorities</li>
            <li><strong>Business Transfers:</strong> In case of merger, acquisition, or sale of assets</li>
            <li><strong>Protection of Rights:</strong> To protect our legal rights, privacy, safety, or property</li>
          </ul>

          <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
            <p class="text-sm text-body-color dark:text-dark-6">
              <strong>Important:</strong> We do not sell your personal data for commercial purposes. Any data sharing is done with strict confidentiality agreements and data protection measures in place.
            </p>
          </div>
        </div>

        <!-- 5. International Data Transfers -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">5. International Data Transfers</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-4">
            As a service provider with clients in India, the US, and the UK, we may transfer your personal data internationally. We ensure such transfers comply with:
          </p>

          <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
            <li><strong>DPDPA Requirements:</strong> We obtain explicit consent before transferring personal data to countries without adequate data protection</li>
            <li><strong>GDPR Mechanisms:</strong> Standard contractual clauses, adequacy decisions, or binding corporate rules</li>
            <li><strong>CCPA Compliance:</strong> Service provider agreements ensuring equivalent privacy protections</li>
          </ul>
        </div>

        <!-- 6. Data Retention -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">6. Data Retention</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-6">
            We retain your personal data for as long as necessary to fulfill the purposes for which it was collected, unless a longer retention period is required by law. Retention periods vary by data type:
          </p>

          <div class="overflow-x-auto">
            <table class="w-full text-sm text-body-color dark:text-dark-6">
              <thead class="bg-gray-100 dark:bg-gray-800">
                <tr>
                  <th class="px-4 py-2 text-left font-semibold">Data Type</th>
                  <th class="px-4 py-2 text-left font-semibold">Retention Period</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b dark:border-gray-700">
                  <td class="px-4 py-2">Account Information</td>
                  <td class="px-4 py-2">As long as your account is active + 1 year</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                  <td class="px-4 py-2">Transaction Records</td>
                  <td class="px-4 py-2">7 years (tax/regulatory compliance)</td>
                </tr>
                <tr class="border-b dark:border-gray-700">
                  <td class="px-4 py-2">Marketing Data</td>
                  <td class="px-4 py-2">Until consent is withdrawn</td>
                </tr>
                <tr>
                  <td class="px-4 py-2">Website Analytics</td>
                  <td class="px-4 py-2">13 months (Google Analytics default)</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 7. Your Rights -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">7. Your Rights</h2>
          
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under DPDPA (India):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Right to access your personal data</li>
              <li>Right to correction and updating of data</li>
              <li>Right to erasure of data</li>
              <li>Right to grievance redressal</li>
            </ul>
          </div>

          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under GDPR (EU/UK):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Right of access to your data</li>
              <li>Right to rectification of inaccurate data</li>
              <li>Right to erasure ("right to be forgotten")</li>
              <li>Right to restrict processing</li>
              <li>Right to data portability</li>
              <li>Right to object to processing</li>
              <li>Rights related to automated decision-making</li>
              <li>Right to lodge a complaint with a supervisory authority</li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Under CCPA (USA):</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li>Right to know what personal information is collected</li>
              <li>Right to delete personal information collected</li>
              <li>Right to opt-out of sale/sharing of personal information</li>
              <li>Right to non-discrimination for exercising CCPA rights</li>
            </ul>
          </div>
        </div>

        <!-- 8. How to Exercise Your Rights -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">8. How to Exercise Your Rights</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-4">
            To exercise any of the above rights, please submit a request to:
          </p>

          <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
            <p class="text-body-color dark:text-dark-6 mb-2">
              <strong>Email:</strong> <a href="mailto:privacy@palportals.com" class="text-primary hover:underline">privacy@palportals.com</a>
            </p>
            <p class="text-body-color dark:text-dark-6 mb-2">
              <strong>Mail:</strong> PAL Portals, [Company Address], India
            </p>
            <p class="text-body-color dark:text-dark-6">
              <strong>Response Time:</strong> We will respond to verified requests within 30 days (45 days for complex requests under GDPR).
            </p>
          </div>
        </div>

        <!-- 9. Data Security -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">9. Data Security</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-4">
            We implement comprehensive security measures to protect your personal data against unauthorized access, alteration, disclosure, or destruction:
          </p>

          <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside mb-6">
            <li>SSL/TLS encryption for data in transit</li>
            <li>Encryption of sensitive data at rest</li>
            <li>Access controls and authentication mechanisms</li>
            <li>Regular security audits and vulnerability assessments</li>
            <li>Employee training on data protection</li>
            <li>Incident response procedures</li>
          </ul>

          <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
            <p class="text-sm text-body-color dark:text-dark-6">
              <strong>Note:</strong> While we implement strong security measures, no method of transmission over the internet or storage is 100% secure. We cannot guarantee absolute security.
            </p>
          </div>
        </div>

        <!-- 10. Cookies and Tracking Technologies -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">10. Cookies and Tracking Technologies</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-4">
            We use cookies and similar technologies to enhance your experience:
          </p>

          <div class="mb-6">
            <h3 class="text-xl font-semibold text-dark dark:text-white mb-3">Types of Cookies:</h3>
            <ul class="space-y-3 text-body-color dark:text-dark-6 list-disc list-inside">
              <li><strong>Essential Cookies:</strong> Required for website functionality</li>
              <li><strong>Performance Cookies:</strong> Analytics and usage tracking</li>
              <li><strong>Preference Cookies:</strong> Remember your settings and choices</li>
              <li><strong>Marketing Cookies:</strong> Tracking for advertising purposes</li>
            </ul>
          </div>

          <p class="text-body-color dark:text-dark-6">
            You can control cookies through your browser settings. However, disabling cookies may affect website functionality.
          </p>
        </div>

        <!-- 11. Third-Party Links -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">11. Third-Party Links</h2>
          
          <p class="text-body-color dark:text-dark-6">
            Our website may contain links to third-party websites. This Privacy Policy does not apply to external sites, and we are not responsible for their privacy practices. We encourage you to review their privacy policies before providing personal information.
          </p>
        </div>

        <!-- 12. Children's Privacy -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">12. Children's Privacy</h2>
          
          <p class="text-body-color dark:text-dark-6">
            Our services are not directed to children under 18 years old (or the applicable age of digital maturity in your jurisdiction). We do not knowingly collect personal data from children. If we become aware that we have collected data from a child, we will delete it immediately. Parents or guardians who believe their child has provided data can contact us at <a href="mailto:privacy@palportals.com" class="text-primary hover:underline">privacy@palportals.com</a>.
          </p>
        </div>

        <!-- 13. Changes to This Policy -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">13. Changes to This Privacy Policy</h2>
          
          <p class="text-body-color dark:text-dark-6">
            We may update this Privacy Policy from time to time to reflect changes in our practices, technology, legal requirements, or other factors. The updated policy will be posted on this page with a new "Effective Date." Your continued use of our services after changes indicates your acceptance of the updated policy. For significant changes, we will provide appropriate notice.
          </p>
        </div>

        <!-- 14. Data Protection Officer and Contact -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-dark dark:text-white mb-4">14. Data Protection Officer and Contact Information</h2>
          
          <p class="text-body-color dark:text-dark-6 mb-4">
            If you have questions about this Privacy Policy or our data practices, please contact:
          </p>

          <div class="p-6 bg-gray-50 dark:bg-gray-800 rounded-lg">
            <p class="text-body-color dark:text-dark-6 mb-2">
              <strong>PAL Portals</strong>
            </p>
            <p class="text-body-color dark:text-dark-6 mb-2">
              <strong>Email:</strong> <a href="mailto:privacy@palportals.com" class="text-primary hover:underline">privacy@palportals.com</a>
            </p>
            <p class="text-body-color dark:text-dark-6 mb-2">
              <strong>Website:</strong> <a href="https://palportals.com" class="text-primary hover:underline">https://palportals.com</a>
            </p>
            <p class="text-body-color dark:text-dark-6">
              <strong>GDPR Complaints:</strong> You may lodge a complaint with your local data protection authority.
            </p>
          </div>
        </div>

        <!-- 15. Acknowledgment -->
        <div class="mb-8 p-6 bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200 dark:border-green-800">
          <h3 class="text-lg font-semibold text-dark dark:text-white mb-2">Compliance Statement</h3>
          <p class="text-sm text-body-color dark:text-dark-6">
            This Privacy Policy is designed to comply with the Digital Personal Data Protection Act, 2023 (India), the General Data Protection Regulation (GDPR), and the California Consumer Privacy Act (CCPA). We are committed to protecting your fundamental right to privacy while conducting business with clients worldwide.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
