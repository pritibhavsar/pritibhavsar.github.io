---
import Breadcrumb from '../components/layout/Breadcrumb.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Legal Notice of PAL Portals - Terms, conditions, disclaimers, and legal information for using our services."
  title="Legal Notice | PAL Portals"
>
  <Breadcrumb>
    <Fragment slot="title">Legal Notice</Fragment>
    <Fragment slot="description">Comprehensive legal terms, conditions, and regulatory compliance information for using PAL Portals services. Compliant with Indian, US, and UK laws.</Fragment>
  </Breadcrumb>

  <section class="py-16 lg:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <!-- Introduction -->
        <div class="mb-12">
          <h1 class="text-3xl font-bold text-dark dark:text-white mb-4">Legal Notice</h1>
          <p class="text-body-color dark:text-dark-6 text-lg">
            <strong>Effective Date:</strong> January 2, 2026
